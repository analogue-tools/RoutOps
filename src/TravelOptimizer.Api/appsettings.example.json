{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=TravelOptimizer;Username=admin;Password=root;Include Error Detail=True"
  },
  "Travel": {
    "Policy": {
      "Strategy": "greedy",
      "MaxExplorationRate": 0.15,
      "PessimisticMultiplier": 1.25,
      "MinSamplesToExplore": 5
    },
    "Reflection": {
      "LookbackDays": 14,
      "AutoPromoteThresholdMinPerDay": 3.0,
      "HighMapeThreshold": 0.25,
      "MinCorridorSamples": 5
    },
    "OpenAI": {
      "ApiKey": "",
      "Model": "gpt-4o-mini",
      "BaseUrl": "https://api.openai.com/v1/"
    },
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "http://localhost:5252/api/calendar/google/callback",
      "SyncWindowDays": 7
    }
  }
}
